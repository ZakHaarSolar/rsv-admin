# Red Solar Viva — Framer Pipeline
# Copia este archivo a .env y completa los valores reales.
# .env NO debe ir al repo (agregalo a .gitignore).

# ────────── Framer Server API ──────────
# URL del proyecto Framer (la que ves en la barra del navegador al editarlo)
FRAMER_PROJECT_URL=https://framer.com/projects/Red-Solar-Viva--jC7xxhLWMiFkzlbPe42f-36qY8

# API key generada en: Framer → Project Settings → General → API Keys
# Formato: 12345678-1234-1234-1234-123456789abc
FRAMER_API_KEY=PEGAR_AQUI_TU_KEY

# ────────── Live Reload (BrowserSync) ──────────
# URL del sitio publicado que el iPhone debe ver
LIVE_RELOAD_TARGET=https://www.redsolarviva.com

# Puerto donde corre el proxy local (el iPhone conecta a http://IP-LAN:PUERTO)
LIVE_RELOAD_PORT=3000

# Puerto interno donde live-reload.mjs escucha el trigger del watcher
LIVE_RELOAD_HOOK_PORT=3010

# URL que el watcher llama post-deploy para refrescar el iPhone
# Si no usás BrowserSync, comentá esta línea y el watcher la ignora
RELOAD_HOOK_URL=http://localhost:3010/reload
